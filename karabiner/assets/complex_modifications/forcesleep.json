{
  "title": "Force Sleep",
  "rules": [
    {
      "description": "Force sleep caps+6",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "6",
            "modifiers": {
              "mandatory": ["left_command", "left_control", "left_option", "left_shift"]
            }
          },
          "to": [
            {
              "shell_command": "~/.local/bin/forcesleep.sh"
            }
          ]
        }
      ]
    }
  ]
}
